{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "ink",
      "camelcase": "Ink",
      "title": "ink",
      "scope": "source.ink",
      "file-types": [
        "k"
      ],
      "injection-regex": "^ink$",
      "class-name": "TreeSitterInk"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "k based array programming language ",
    "authors": [
      {
        "name": "Werner Laurensse"
      }
    ],
    "links": {
      "repository": "http://foliant.net/"
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true,
    "zig": false
  }
}